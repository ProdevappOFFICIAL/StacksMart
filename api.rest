# SolStore API - Authentication Endpoints
# Base URL: http://localhost:4000

@baseUrl = http://localhost:4000
@apiVersion = v1


# Store the token from login/register responses here
@authToken = YOUR_JWT_TOKEN_HERE

###############################################################################
# AUTHENTICATION ENDPOINTS
###############################################################################

### 1. Register User
# POST {{baseUrl}}/{{apiVersion}}/auth/register
POST {{baseUrl}}/{{apiVersion}}/auth/register
Content-Type: application/json

{
  "email": "{{testEmail}}",
  "password": "{{testPassword}}",
  "walletAddress": "{{testWalletAddress}}"
}

### 2. Register User - Different wallet for testing
POST {{baseUrl}}/{{apiVersion}}/auth/register
Content-Type: application/json

{
  "email": "user2@example.com",
  "password": "password456",
  "walletAddress": "8WzDXwBbmkg8ZTbNMqUxvQRAyrZzDsGYdLVL9zYtAWWN"
}

### 3. Login User
POST {{baseUrl}}/{{apiVersion}}/auth/login
Content-Type: application/json

{
  "email": "{{testEmail}}",
  "password": "{{testPassword}}",
  "walletAddress": "{{testWalletAddress}}"
}

### 4. Wallet Connect (existing endpoint)
POST {{baseUrl}}/{{apiVersion}}/auth/wallet/connect
Content-Type: application/json

{
  "walletAddress": "{{testWalletAddress}}",
  "signature": "{{testSignature}}",
  "message": "{{testMessage}}"
}

### 5. Verify Token
GET {{baseUrl}}/{{apiVersion}}/auth/verify
Authorization: Bearer {{authToken}}

